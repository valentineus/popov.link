---
import type { Thing } from "schema-dts";

type Props = {
	readonly schema: Thing[];
};

const { schema } = Astro.props;

const payload = {
	"@context": "https://schema.org",
	"@graph": schema,
};

const json = JSON.stringify(payload);
---

<!-- JSON-LD -->
<script is:inline type="application/ld+json" set:html={json} />
